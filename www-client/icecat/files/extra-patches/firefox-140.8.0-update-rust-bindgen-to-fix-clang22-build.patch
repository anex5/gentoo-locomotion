-#[inline]
-fn round_up(num: &mut Buf12, scale: i32) -> Result<i32, DivError> {
-    let low64 = num.low64().wrapping_add(1);
-    num.set_low64(low64);
-    if low64 != 0 {
-        return Ok(scale);
-    }
-    let hi = num.data[2].wrapping_add(1);
-    num.data[2] = hi;
-    if hi != 0 {
-        return Ok(scale);
-    }
-    unscale_from_overflow(num, scale, true)
-}
