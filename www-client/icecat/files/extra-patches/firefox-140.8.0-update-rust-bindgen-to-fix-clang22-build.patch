-    if (RD && RD->isCompleteDefinition() &&
-        (RD->hasTrivialMoveConstructor() ||
-         (!RD->hasMoveConstructor() && RD->hasTrivialCopyConstructor())) &&
-        RD->hasTrivialDestructor()) {
+    if (is_trivially_relocatable(D)) {
