+    /// Parses a structured-field value from the given parser.
+    ///
+    /// # Errors
+    /// When the parsing process is unsuccessful.
+    fn parse(parser: Parser<'_>) -> Result<Self, Error>
+    where
+        Self: Sized;
+}
