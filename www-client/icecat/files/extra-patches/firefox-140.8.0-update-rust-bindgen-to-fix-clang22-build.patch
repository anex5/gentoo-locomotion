-#[inline(never)]
-#[cold]
-fn maybe_round(
-    mut data: u128,
-    next_byte: u8,
-    mut scale: u8,
-    point: bool,
-    negative: bool,
-) -> Result<Decimal, crate::Error> {
-    let digit = match next_byte {
-        b'0'..=b'9' => u32::from(next_byte - b'0'),
-        b'_' => 0, // this should be an invalid string?
-        b'.' if point => 0,
-        b => return tail_invalid_digit(b),
