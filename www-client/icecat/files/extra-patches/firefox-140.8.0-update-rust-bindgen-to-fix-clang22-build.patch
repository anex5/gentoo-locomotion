-        Some((u64::from(d.mid) << 32) | u64::from(d.lo))
-    }
-
-    fn to_u128(&self) -> Option<u128> {
-        if self.is_sign_negative() {
-            return None;
-        }
-
-        let d = self.trunc();
-        Some((u128::from(d.hi) << 64) | (u128::from(d.mid) << 32) | u128::from(d.lo))
