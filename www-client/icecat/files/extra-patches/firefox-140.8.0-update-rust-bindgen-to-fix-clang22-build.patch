-        let mut zero = ZERO;
-        if !positive {
-            zero.set_sign_negative(true);
-        }
-        return Some(zero);
-    }
-
-    // Get the bits and exponent2
-    let mut exponent2 = biased_exponent - 127;
-    let mut bits = [mantissa, 0u32, 0u32];
-    if biased_exponent == 0 {
-        // Denormalized number - correct the exponent
-        exponent2 += 1;
