-        // Otherwise, we calculate a standard unsigned exponent
-        if exp >= 0 {
-            return self.checked_powu(exp as u64);
-        }
-
-        // Get the unsigned exponent
-        let exp = exp.unsigned_abs();
-        let pow = match self.checked_powu(exp) {
-            Some(v) => v,
-            None => return None,
-        };
-        Decimal::ONE.checked_div(pow)
-    }
