+
+impl EchExtensionHandler {
+    const INNER: &[u8] = b"inner is longer";
+    const OUTER: &[u8] = b"outer";
+
+    pub const fn negotiated(&self, outer_written: bool) -> bool {
+        self.written_inner && self.written_outer == outer_written && self.handled
+    }
