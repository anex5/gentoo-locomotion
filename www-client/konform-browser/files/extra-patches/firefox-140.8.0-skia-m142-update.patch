diff --git a/gfx/skia/skia/src/core/SkPathPriv.cpp b/gfx/skia/skia/src/core/SkPathPriv.cpp
new file mode 100644
index 000000000000..61c340173e0a
--- /dev/null
+++ b/gfx/skia/skia/src/core/SkPathPriv.cpp
@@ -0,0 +1,256 @@
+/*
