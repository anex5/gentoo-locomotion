diff --git a/gfx/skia/skia/include/gpu/vk/VulkanPreferredFeatures.h b/gfx/skia/skia/include/gpu/vk/VulkanPreferredFeatures.h
new file mode 100644
index 000000000000..3810a42380b1
--- /dev/null
+++ b/gfx/skia/skia/include/gpu/vk/VulkanPreferredFeatures.h
@@ -0,0 +1,217 @@
+/*
