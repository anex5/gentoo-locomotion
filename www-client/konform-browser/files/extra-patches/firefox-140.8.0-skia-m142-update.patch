+static inline SkPathConvexity SkPathDirection_ToConvexity(SkPathDirection dir) {
+    switch (dir) {
+        case SkPathDirection::kCW:  return SkPathConvexity::kConvex_CW;
+        case SkPathDirection::kCCW: return SkPathConvexity::kConvex_CCW;
+    }
