+static SkSpan<Coordinate> Normalize(SkSpan<Coordinate> variation) {
+    for (auto&& coord : variation) {
+        if (coord.value == 0 || SkIsNaN(coord.value)) {
+            coord.value = 0.0f;
+        }
+    }
+    return variation;
+}
